HERMES_CONTAINER_NAME=hermes-gateway
HERMES_IMAGE_NAME=wireguard-hermes-gateway:local
HERMES_BASE_IMAGE=nousresearch/hermes-agent:latest
HERMES_GATEWAY_PORT=8642
HERMES_DASHBOARD_PORT=9119
HERMES_WORKSPACE_ROOT=..
HERMES_RUNTIME_ENV_FILE=./runtime/hermes.runtime.env
HERMES_BOOTSTRAP_HOME=./runtime/bootstrap
HERMES_AUTO_UPDATE=true
HERMES_AUTO_UPDATE_ARGS=--yes --gateway
HERMES_AUTO_UPDATE_REQUIRED=false
HERMES_AGENT_MODEL_MODE=Local
HERMES_MODEL_PROVIDER=auto
HERMES_MODEL_DEFAULT=gpt-5.4
HERMES_MODEL_BASE_URL=
HERMES_MODEL_API_KEY=
HERMES_CODEX_MODEL=gpt-5.4
HERMES_LOCAL_MODEL_BASE_URL=http://host.docker.internal:8068/v1
HERMES_LOCAL_MODEL_ID=qwen36_35b_a3b_mtp_iq3xxs_rx6800_cache_mtp_256k
HERMES_LOCAL_MODEL_API_KEY=local-model
HERMES_DISCORD_ENABLED=false
HERMES_DISCORD_REQUIRE_MENTION=true
HERMES_DISCORD_AUTO_THREAD=true
